# Base URL of the backend API (used for Axios and SSE)
VITE_API_BASE_URL=http://localhost:8123/api

# Base URL for the generated website preview (static files served by backend)
# Format: {VITE_PREVIEW_BASE_URL}/static/{codeGenType}_{appId}/
VITE_PREVIEW_BASE_URL=http://localhost:8123/api

# Base URL for deployed apps
# Format: {VITE_DEPLOY_BASE_URL}/{deployKey}
VITE_DEPLOY_BASE_URL=http://localhost
