# Backend API base URL (used for Axios requests and SSE streaming)
VITE_API_BASE_URL=/api

# Deployed-app root domain — getDeployUrl(deployKey) → {VITE_DEPLOY_BASE_URL}/{deployKey}
VITE_DEPLOY_BASE_URL=http://localhost

# NOTE: Static-preview URL is derived automatically in src/config/env.ts as:
#   {VITE_API_BASE_URL}/static/{codeGenType}_{appId}/
# No need to set VITE_PREVIEW_BASE_URL separately.
